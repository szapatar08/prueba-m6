{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=prueba;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE_OR_USER_SECRETS",
    "Issuer": "PruebaApi",
    "Audience": "PruebaClient",
    "ExpiresInMinutes": 15
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "Kyc": {
    "ConfidenceThreshold": 80
  }
}
